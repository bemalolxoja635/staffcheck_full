{
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://staffcheck-production.up.railway.app/api/$1"
    },
    {
      "source": "/admin/(.*)",
      "destination": "https://staffcheck-production.up.railway.app/admin/$1"
    },
    {
      "source": "/static/(.*)",
      "destination": "https://staffcheck-production.up.railway.app/static/$1"
    },
    {
      "source": "/media/(.*)",
      "destination": "https://staffcheck-production.up.railway.app/media/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
